<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:SaveMail.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="SaveMail.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="{StaticResource AppIcon}"
        Title="SaveMail"
        FontFamily="{StaticResource Helvetica}"
        Background="{DynamicResource PrimaryBackground}"
        MinHeight="730" MinWidth="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        
        <Style Selector="Button.ClearBtn">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Button.ClearBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>

        <Style Selector="Button.ClearBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Button.ClearBtn:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Button.ClearBtn:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        
        <Style Selector="TextBlock.SectionTitle">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,20,0,10"/>
        </Style>
        <Style Selector="ToggleSwitch">
            <Setter Property="OnContent" Value="{x:Null}"/>
            <Setter Property="OffContent" Value="{x:Null}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <Style Selector="Button.ActionBtn">
            <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundSolid}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        
        <Style Selector="Border.drop-zone">
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.drop-zone.drag-active">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>

        <Style Selector="Border.drop-zone.drag-active Rectangle">
            <Style.Animations>
                <Animation Duration="0:0:0.5" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="StrokeDashOffset" Value="12"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="StrokeDashOffset" Value="0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        
        <Style Selector="Border.queue-item">
            <Style.Animations>
                <Animation Duration="0:0:0.3" Easing="CubicEaseOut" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Margin" Value="0,20,0,-10"/>
                    </KeyFrame>
            
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="Margin" Value="0,0,0,10"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        
        <Style Selector="Border.queue-item.removing">
            <Style.Animations>
                <Animation Duration="0:0:0.3" Easing="CubicEaseIn" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="Margin" Value="0,0,0,10"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Margin" Value="40,0,-40,10"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="*, 360">
        
        <Grid Grid.Column="0" RowDefinitions="Auto, Auto, *" Margin="30">
            
            <Border x:Name="DropZoneBorder"
                    Classes="drop-zone"
                    Grid.Row="0" Background="{DynamicResource DropForeground}" 
                    CornerRadius="{DynamicResource CardCornerRadius}" Margin="0,0,0,30"
                    DragDrop.AllowDrop="True"
                    DragDrop.DragEnter="DropZone_DragEnter"
                    DragDrop.DragLeave="DropZone_DragLeave"
                    DragDrop.DragOver="DropZone_DragOver"
                    DragDrop.Drop="DropZone_Drop">
    
                <Grid>
                    <Rectangle Stroke="{DynamicResource DropTirets}" StrokeThickness="2" 
                               StrokeDashArray="6,6" RadiusX="12" RadiusY="12"/>
        
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
                        <Border Background="{DynamicResource DropForeground}" Width="60" Height="60" 
                                CornerRadius="30" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="{StaticResource IconeUpload}" FontFamily="{StaticResource Phosphor}" 
                                       Foreground="{DynamicResource PrimaryForeground}" 
                                       FontSize="{StaticResource IconSizeMedium}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                        <TextBlock Text="Glissez-déposez vos emails ici" FontWeight="Bold" 
                                   FontSize="{StaticResource FontSizeMedium}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Formats supportés : .eml, .msg" Foreground="{DynamicResource SecondaryForeground}" 
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15">
                            <Button Classes="ActionBtn" Content="Parcourir les fichiers" Click="BtnAddFiles_Click"/>
                            <Button Classes="ActionBtn" Content="Ajouter un dossier" Click="BtnAddFolder_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="File d'attente (" FontWeight="Bold" FontSize="{StaticResource FontSizeNormal}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding QueueCount}" FontWeight="Bold" FontSize="{StaticResource FontSizeNormal}" VerticalAlignment="Center"/>
                    <TextBlock Text=")" FontWeight="Bold" FontSize="{StaticResource FontSizeNormal}" VerticalAlignment="Center"/>
                </StackPanel>
                
                <Button Grid.Column="1" Classes="ClearBtn" Padding="0" Click="BtnClearQueue_Click" Cursor="Hand" IsEnabled="{Binding HasFiles}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="{StaticResource IconeTrash}" FontFamily="{StaticResource Phosphor}" 
                                   Foreground="{DynamicResource ColorFontRed}" VerticalAlignment="Center"/>
                        <TextBlock Text="Vider la liste" Foreground="{DynamicResource ColorFontRed}" 
                                   FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

           <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
               <ItemsControl x:Name="QueueItemsControl" ItemsSource="{Binding FilesQueue}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderColor}" Classes="queue-item"
                                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="0"
                                    Classes.success="{Binding IsCompleted}"
                                    Classes.error="{Binding HasError}"
                                    Classes.warning="{Binding HasWarning}"> <Border.Styles>
                                    <Style Selector="Border">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundSolid}"/>
                                    </Style>
                                    <Style Selector="Border.success">
                                        <Setter Property="Background" Value="{DynamicResource SuccessBackground}"/>
                                    </Style>
                                    <Style Selector="Border.warning">
                                        <Setter Property="Background" Value="{DynamicResource WarningBackground}"/>
                                    </Style>
                                    <Style Selector="Border.error">
                                        <Setter Property="Background" Value="{DynamicResource ErrorBackground}"/>
                                    </Style>
                                </Border.Styles>

                                <Grid>
                                    
                                    <Grid ColumnDefinitions="Auto, *, Auto" Margin="15">
                                        
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="{DynamicResource ControlCornerRadius}" 
                                                Background="{DynamicResource MailIconeBackground}" Margin="0,0,15,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{StaticResource IconeMail}" FontFamily="{StaticResource Phosphor}" 
                                                       Foreground="{DynamicResource MailIconeForeground}" FontSize="{StaticResource IconSizeNormal}" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Name}" FontSize="{StaticResource FontSizeNormal}" 
                                                       TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{Binding Size}" Foreground="{DynamicResource SecondaryForeground}" FontSize="{StaticResource FontSizeSmall}"/>
                                                <TextBlock Text="•" Foreground="{DynamicResource SecondaryForeground}" FontSize="{StaticResource FontSizeSmall}"/>
                                                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource SecondaryForeground}" FontSize="{StaticResource FontSizeSmall}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        
                                        <Grid Grid.Column="2" ColumnDefinitions="Auto, Auto" VerticalAlignment="Center">
    
                                            <Border Grid.Column="0" Width="36" Margin="0,0,10,0" Background="Transparent">
                                                <TextBlock Text="{StaticResource IconeCheckCircle}" FontFamily="{StaticResource Phosphor}" 
                                                           Foreground="{DynamicResource SuccessForeground}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent"
                                                           Classes.completed="{Binding IsCompleted}">
                                                    <TextBlock.Styles>
                                                        <Style Selector="TextBlock">
                                                            <Setter Property="Opacity" Value="0"/>
                                                        </Style>
                                                        <Style Selector="TextBlock.completed">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </Style>
                                                    </TextBlock.Styles>
                                                </TextBlock>
                                            </Border>
    
                                            <Button Grid.Column="1" Background="Transparent" Padding="8" CornerRadius="20" 
                                                    Cursor="Hand" Click="BtnRemoveItem_Click" 
                                                    Classes.processing="{Binding IsProcessing}">
                                                <TextBlock Text="{StaticResource IconeClose}" FontFamily="{StaticResource Phosphor}" 
                                                           Foreground="{DynamicResource SecondaryForeground}" FontSize="{StaticResource IconSizeMedium}"/>
                                                <Button.Styles>
                                                    <Style Selector="Button">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Setter Property="IsHitTestVisible" Value="True"/> </Style>
                                                    <Style Selector="Button.processing">
                                                        <Setter Property="Opacity" Value="0"/>
                                                        <Setter Property="IsHitTestVisible" Value="False"/> </Style>
                                                </Button.Styles>
                                            </Button>
                                        </Grid>
                                    </Grid>

                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" 
                                                 Height="4" CornerRadius="0,0,8,8"
                                                 VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                                 Foreground="{DynamicResource PrimaryForeground}"
                                                 Classes.processing="{Binding IsProcessing}">
                                        <ProgressBar.Styles>
                                            <Style Selector="ProgressBar">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Setter Property="Transitions">
                                                    <Transitions>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                                                    </Transitions>
                                                </Setter>
                                            </Style>
                                            <Style Selector="ProgressBar.processing">
                                                <Setter Property="Opacity" Value="1"/>
                                            </Style>
                                        </ProgressBar.Styles>
                                    </ProgressBar>
                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="1" Background="{DynamicResource PrimaryBackgroundSolid}" 
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0">
            <Grid RowDefinitions="*, Auto">
                
                <ScrollViewer Grid.Row="0" Padding="30">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{StaticResource IconeGear}" FontFamily="{StaticResource Phosphor}" 
                                       Foreground="{DynamicResource SecondaryForeground}" FontSize="{StaticResource IconSizeMedium}" 
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Paramètres d'export" FontWeight="Bold" FontSize="{StaticResource FontSizeMedium}" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="DOSSIER DE SORTIE" Classes="SectionTitle"/>
                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                            <Border Grid.Column="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" 
                                    CornerRadius="{DynamicResource FieldCornerRadius}" Background="{DynamicResource FieldBackground}" Padding="10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{StaticResource IconeFolder}" FontFamily="{StaticResource Phosphor}" 
                                               Foreground="{DynamicResource SecondaryForeground}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding OutputDirectory}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource SecondaryForeground}" 
                                               VerticalAlignment="Center" MaxWidth="180"/>
                                </StackPanel>
                            </Border>
                            <Button Grid.Column="1" Content="..." Classes="ActionBtn" Margin="10,0,0,0" Click="BtnSelectOutput_Click"/>
                        </Grid>

                        <TextBlock Text="CONTENU DU PDF" Classes="SectionTitle"/>
                        <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                            <TextBlock Text="Inclure l'en-tête de l'e-mail" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IncludeHeader, Mode=TwoWay}"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                            <TextBlock Text="Extraire les pièces jointes" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ExtractAttachments, Mode=TwoWay}"/>
                        </Grid>
                        
                        
                        <Grid ColumnDefinitions="*, Auto" Margin="0,5" IsEnabled="{Binding IsAddAttachmentsToPdfEnabled}">
                            <TextBlock Text="Ajouter pièce jointe au pdf" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AddAttachmentsToPdf, Mode=TwoWay}"/>
                        </Grid>

                        <TextBlock Text="GESTION DES ARCHIVES" Classes="SectionTitle" IsEnabled="{Binding IsArchiveSectionEnabled}"/>
                        
                        <Grid ColumnDefinitions="*, Auto" Margin="0,5" IsEnabled="{Binding IsArchiveUnsupportedEnabled}">
                            <TextBlock Text="Archiver les formats non supportés" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ArchiveUnsupported, Mode=TwoWay}"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*, Auto" Margin="0,5" IsEnabled="{Binding IsArchiveSectionEnabled}">
                            <TextBlock Text="Tout regrouper dans une archive (.zip)" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ZipEverything, Mode=TwoWay}"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*, Auto" Margin="0,5" IsEnabled="{Binding IsArchiveSectionEnabled}">
                            <TextBlock Text="Conserver l'e-mail d'origine" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding KeepOriginalEmail, Mode=TwoWay}"/>
                        </Grid>

                        <TextBlock Text="POST-TRAITEMENT" Classes="SectionTitle"/>
                        <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                            <TextBlock Text="Ouvrir le dossier à la fin" VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding OpenFolderAtEnd, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="30">
                    <StackPanel>
                        <Button Background="{DynamicResource BoutonColorBlue}" Foreground="White" 
                                CornerRadius="{DynamicResource ControlCornerRadius}" Padding="15" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="BtnProcess_Click"
                                IsEnabled="{Binding HasPendingFiles}"> <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <TextBlock Text="{StaticResource IconeExportFile}" FontFamily="{StaticResource Phosphor}" 
                                           FontSize="{StaticResource IconSizeSmall}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="Convertir (" FontWeight="Bold" FontSize="{StaticResource FontSizeNormal}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PendingCount}" FontWeight="Bold" FontSize="{StaticResource FontSizeNormal}" VerticalAlignment="Center"/> <TextBlock Text=")" FontWeight="Bold" FontSize="{StaticResource FontSizeNormal}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0" Spacing="5">
                            <TextBlock Text="{StaticResource IconeCheckCircle}" FontFamily="{StaticResource Phosphor}" 
                                       Foreground="{DynamicResource InfoFont}" Background="Transparent" VerticalAlignment="Center"/>
                            <TextBlock Text="Traitement 100% local" Foreground="{DynamicResource InfoFont}" 
                                       FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>